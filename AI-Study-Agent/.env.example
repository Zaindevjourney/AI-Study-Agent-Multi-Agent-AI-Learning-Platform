# Copy this file to .env and fill in whichever provider you use.
# If neither is set, the LLMClient automatically falls back to a
# mock mode so the whole project still runs for demos/testing.

GEMINI_API_KEY=
OPENAI_API_KEY=

# Optional: for the Reminder Agent's real email sending
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
